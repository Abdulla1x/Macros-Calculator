# Database. Defaults to a local SQLite file (repo-root macros.db) when unset.
# Production (Neon): postgresql+psycopg://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=

# Secret for signing JWT access tokens. REQUIRED in production (any non-SQLite
# database refuses to start without it). Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# Access token lifetime in days (default 7).
ACCESS_TOKEN_DAYS=7

# Gemini API key for AI meal analysis. Feature returns 503 when unset.
GEMINI_API_KEY=

# Per-user daily cap on AI analyses (default 20). Protects the shared Gemini quota.
AI_DAILY_LIMIT=20

# Comma-separated allowed CORS origins (default: local Vite dev server).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
